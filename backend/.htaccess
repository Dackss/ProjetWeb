RewriteEngine On

RewriteCond %{REQUEST_URI} ^/dist/
RewriteRule ^ - [L]

RewriteCond %{REQUEST_URI} ^/api/
RewriteRule ^ - [L]

RewriteCond %{REQUEST_URI} ^/index\.php
RewriteRule ^ - [L]

RewriteCond %{DOCUMENT_ROOT}/dist%{REQUEST_URI} -f
RewriteRule ^(.*)$ /dist$1 [L]

RewriteRule ^ /dist/index.html [L]
